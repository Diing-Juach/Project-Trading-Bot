# Copy this file to `.env` and replace the placeholder values.
# Keep `.env` private and out of version control.

# -----------------------------
# MetaTrader 5 credentials
# -----------------------------
MT5_LOGIN=YOUR_MT5_LOGIN
MT5_PASSWORD=YOUR_MT5_PASSWORD
MT5_SERVER=YOUR_MT5_SERVER

# -----------------------------
# Optional backtest overrides
# These map to src/mt5/config.py.
# Leave them commented out if you want to use the defaults from config.py.
# -----------------------------

# TBOT_SYMBOLS=EURUSD
# TBOT_TIMEFRAMES=M30
# TBOT_START_DATE=2020-01-01
# TBOT_END_DATE=2026-01-01

# TBOT_INITIAL_CASH=10000
# TBOT_RISK_PCT=0.01
# TBOT_TARGET_RR=2.0

# TBOT_COMMISSION_PER_LOT=6.0
# TBOT_BASE_SPREAD_PIPS=0.7
# TBOT_SLIPPAGE_PIPS=0.5

# TBOT_USE_RAW_CACHE=true
# TBOT_USE_FEATURE_CACHE=true
# TBOT_FORCE_REBUILD_FEATURES=false
# TBOT_PRINT_STAGE_TIMINGS=true

# -----------------------------
# Optional feature toggles
# -----------------------------

# TBOT_USE_SESSION_LIQUIDITY=true
# TBOT_USE_VOLUME_PROFILE=true
# TBOT_USE_IMBALANCE=true
# TBOT_USE_FIBONACCI=true
# TBOT_USE_LIQUIDITY=true
# TBOT_USE_SUPPORT_RESISTANCE=true
